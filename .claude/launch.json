{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "erp-docker",
      "runtimeExecutable": "/Applications/Docker.app/Contents/Resources/bin/docker",
      "runtimeArgs": ["compose", "up", "app"],
      "port": 3010
    },
    {
      "name": "erp-dev",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "NEXT_DIST_DIR=.next-preview npm run dev -- -p 3011"],
      "port": 3011
    },
    {
      "name": "erp-dev-auto",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3012,
      "autoPort": true
    },
    {
      "name": "erp-dev-localauth",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "AUTH_URL=http://localhost:3015 NEXT_DIST_DIR=.next-preview npm run dev -- -p 3015"],
      "port": 3015
    },
    {
      "name": "erp-dev-localauth-3016",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "AUTH_URL=http://localhost:3016 NEXT_DIST_DIR=.next-preview-3016 npm run dev -- -p 3016"],
      "port": 3016
    },
    {
      "name": "erp-dev-preview2",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "NEXT_DIST_DIR=.next-preview-2 npm run dev"],
      "port": 3013,
      "autoPort": true
    }
  ]
}
