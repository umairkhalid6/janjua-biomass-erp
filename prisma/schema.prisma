// Janjua Biomass ERP — data model
// Money is PKR stored as Decimal(14,2). Production and sales are measured in
// 40-kg bags (BAG_KG = 40, see src/lib/constants.ts); purchases are in KG.
// Report aggregations live in SQL views (see prisma/migrations/*_views).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
}

enum MaterialType {
  POPLAR
  HARDWOOD
  HAIDERI_PLYWOOD
  WOOD_CHIPS
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(OPERATOR)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  sales        PelletSale[]
  productionCreated ProductionDay[] @relation("ProductionDayCreatedBy")
  productionUpdated ProductionDay[] @relation("ProductionDayUpdatedBy")
  productionDayCreated   ProductionDay[] @relation("ProductionDayShiftCreatedBy")
  productionDayUpdated   ProductionDay[] @relation("ProductionDayShiftUpdatedBy")
  productionNightCreated ProductionDay[] @relation("ProductionNightShiftCreatedBy")
  productionNightUpdated ProductionDay[] @relation("ProductionNightShiftUpdatedBy")

  @@map("users")
}

model Customer {
  id             String            @id @default(cuid())
  name           String
  company        String?
  phone          String?
  // Amount the customer already owed us when they were added (carried from the
  // old sheets). Positive = they owe us; negative = advance/credit on account.
  openingBalance Decimal           @default(0) @db.Decimal(14, 2)
  createdAt      DateTime          @default(now())
  sales          PelletSale[]
  payments       CustomerPayment[]

  @@map("customers")
}

// A supplier of raw biomass feedstock (formerly "Vendor").
model Supplier {
  id             String             @id @default(cuid())
  name           String
  phone          String?
  notes          String?
  // Amount we already owed the supplier when they were added (carried from the
  // old sheets). Positive = we owe them.
  openingBalance Decimal            @default(0) @db.Decimal(14, 2)
  createdAt      DateTime           @default(now())
  purchases      MaterialPurchase[]
  payments       SupplierPayment[]

  @@map("suppliers")
}

// Collapses the 4 identical purchase sheets (Poplar / Hard Wood / Haideri
// Plywood sawdust + Chipper for Crusher) into one table keyed by materialType.
model MaterialPurchase {
  id           String       @id @default(cuid())
  date         DateTime     @db.Date
  materialType MaterialType
  supplierId   String
  supplier     Supplier     @relation(fields: [supplierId], references: [id])
  weightKg     Decimal      @db.Decimal(12, 2)
  materialCost Decimal      @db.Decimal(14, 2)
  handlingCost Decimal      @default(0) @db.Decimal(14, 2) // unloading / gari expense
  ratePerKg    Decimal      @default(0) @db.Decimal(12, 2) // (materialCost + handlingCost) / weightKg
  notes        String?
  createdAt    DateTime     @default(now())
  payments     SupplierPayment[]

  @@index([date])
  @@index([materialType, date])
  @@map("material_purchases")
}

model SupplierPayment {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  amount     Decimal  @db.Decimal(14, 2)
  method     String   @default("Cash") // Cash / Bank / Cheque / Online
  notes      String?
  // Set when the payment was made against a specific purchase (at purchase
  // entry or from the supplier page). The money is real even if the purchase
  // is later deleted, so the link severs (SET NULL) rather than cascades.
  purchaseId String?
  purchase   MaterialPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([date])
  @@index([purchaseId])
  @@map("supplier_payments")
}

// Money received from a customer against their outstanding balance (receipts).
model CustomerPayment {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  amount     Decimal  @db.Decimal(14, 2)
  method     String   @default("Cash") // Cash / Bank / Cheque / Online
  notes      String?
  // Set when the payment was received against a specific invoice (at sale
  // entry or from the invoice page). The money is real even if the invoice
  // is later deleted, so the link severs (SET NULL) rather than cascades.
  saleId     String?
  sale       PelletSale? @relation(fields: [saleId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([date])
  @@index([saleId])
  @@map("customer_payments")
}

model PelletSale {
  id           String   @id @default(cuid())
  invoiceNo    Int      @unique @default(autoincrement())
  date         DateTime @db.Date
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  quantityBags Decimal  @db.Decimal(12, 2)
  // Net pellet price per bag. The customer-facing (invoice) rate is
  // ratePerBag + loadingChargePerBag; the split keeps loading income out of
  // pellet revenue in reports (see LOADING_CHARGE_PER_BAG in constants.ts).
  ratePerBag         Decimal @db.Decimal(12, 2)
  loadingChargePerBag Decimal @default(0) @db.Decimal(12, 2)
  notes        String?
  // Unguessable token for the public (no-auth) invoice link shared on WhatsApp.
  // Null until an invoice is first shared; generated lazily.
  shareToken   String?  @unique
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  payments     CustomerPayment[]

  @@index([date])
  @@map("pellet_sales")
}

model ProductionDay {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  dayShiftBags   Decimal  @default(0) @db.Decimal(12, 2)
  nightShiftBags Decimal  @default(0) @db.Decimal(12, 2)
  notes          String?
  createdById    String?
  createdBy      User?    @relation("ProductionDayCreatedBy", fields: [createdById], references: [id])
  // Last user who edited the row after creation; null while untouched.
  updatedById    String?
  updatedBy      User?    @relation("ProductionDayUpdatedBy", fields: [updatedById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  // Day and night shifts are independent entries: each shift tracks who first
  // entered it and who last edited it, so the audit trail is per shift.
  dayCreatedById   String?
  dayCreatedBy     User?     @relation("ProductionDayShiftCreatedBy", fields: [dayCreatedById], references: [id])
  dayUpdatedById   String?
  dayUpdatedBy     User?     @relation("ProductionDayShiftUpdatedBy", fields: [dayUpdatedById], references: [id])
  dayUpdatedAt     DateTime?
  nightCreatedById String?
  nightCreatedBy   User?     @relation("ProductionNightShiftCreatedBy", fields: [nightCreatedById], references: [id])
  nightUpdatedById String?
  nightUpdatedBy   User?     @relation("ProductionNightShiftUpdatedBy", fields: [nightUpdatedById], references: [id])
  nightUpdatedAt   DateTime?

  @@map("production_days")
}

model Expense {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  item      String
  amount    Decimal  @db.Decimal(14, 2)
  category  String   @default("Maintenance")
  createdAt DateTime @default(now())

  @@index([date])
  @@map("expenses")
}

model ElectricityBill {
  id            String   @id @default(cuid())
  month         DateTime @unique @db.Date // first day of the billing month
  billAmount    Decimal  @db.Decimal(14, 2)
  unitsConsumed Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  @@map("electricity_bills")
}

// Thekadar (contractor) rate history — labor cost = bags × 40 kg × rate_per_kg.
model ContractorRate {
  id            String   @id @default(cuid())
  effectiveFrom DateTime @unique @db.Date
  ratePerKg     Decimal  @db.Decimal(8, 2)
  createdAt     DateTime @default(now())

  @@map("contractor_rates")
}

model ContractorPayment {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  amount    Decimal  @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
  @@map("contractor_payments")
}

// Manual ledger entries: positive = owed to contractor (e.g. opening balance
// carried from the old sheets), negative = owed by contractor.
model ContractorAdjustment {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  amount    Decimal  @db.Decimal(14, 2)
  reason    String
  createdAt DateTime @default(now())

  @@unique([date, reason])
  @@map("contractor_adjustments")
}
